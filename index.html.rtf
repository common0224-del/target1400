    \};\
\
    const vocab = RAW_DATA.split('\\n').map(line => \{\
      const [no, word, meaning] = line.split('\\t');\
      return \{ no: Number(no), word, meaning, pos: detectPos(meaning) \};\
    \}).filter(v => v.word && v.meaning);\
\
    function detectPos(meaning) \{\
      if (meaning.startsWith('\uc0\u12434 ') || meaning.startsWith('\u12395 ') || meaning.startsWith('\u12392 ') || meaning.startsWith('\u12364 ') || meaning.includes('\u12377 \u12427 ') || meaning.includes('\u12394 \u12427 ') || meaning.includes('\u12354 \u12427 ') || meaning.includes('\u12356 \u12427 ')) return 'verb';\
      if (meaning.endsWith('\uc0\u12398 ') || meaning.endsWith('\u12394 ') || meaning.includes('\u30340 \u12394 ') || meaning.includes('\u21487 \u33021 \u12394 ') || meaning.includes('\u23433 \u20840 \u12394 ')) return 'adjective';\
      if (meaning.includes('\uc0\u12395 ') && !meaning.startsWith('\u12395 ')) return 'adverb';\
      return 'noun';\
    \}\
\
    function shuffle(arr) \{\
      const a = [...arr];\
      for (let i = a.length - 1; i > 0; i--) \{\
        const j = Math.floor(Math.random() * (i + 1));\
        [a[i], a[j]] = [a[j], a[i]];\
      \}\
      return a;\
    \}\
\
    function sample(arr, n) \{ return shuffle(arr).slice(0, n); \}\
\
    function inferVerbType(meaning) \{\
      return (meaning.startsWith('\uc0\u12434 ') || meaning.startsWith('\u12395 ') || meaning.includes('\u12434 ')) ? 'transitive' : 'intransitive';\
    \}\
\
    function genericExample(entry) \{\
      if (entry.pos === 'verb') \{\
        if (inferVerbType(entry.meaning) === 'transitive') \{\
          return [`Our teacher asked us to $\{entry.word\} the main idea in one sentence.`, `\uc0\u20808 \u29983 \u12399 \u31169 \u12383 \u12385 \u12395 \u20027 \u12394 \u32771 \u12360 \u12434 1\u25991 \u12391 \u34920 \u12377 \u12424 \u12358 \u27714 \u12417 \u12383 \u12290 `];\
        \}\
        return [`Students often $\{entry.word\} when they work in groups.`, `\uc0\u29983 \u24466 \u12399 \u12464 \u12523 \u12540 \u12503 \u12391 \u27963 \u21205 \u12377 \u12427 \u12392 \u12365 \u12395 \u12424 \u12367 \u12381 \u12398 \u12424 \u12358 \u12395 \u34892 \u21205 \u12377 \u12427 \u12290 `];\
      \}\
      if (entry.pos === 'adjective') \{\
        return [`This method is simple but very $\{entry.word\}.`, `\uc0\u12371 \u12398 \u26041 \u27861 \u12399 \u31777 \u21336 \u12384 \u12364 \u12289 \u12381 \u12398 \u35486 \u12398 \u24847 \u21619 \u12395 \u21512 \u12358 \u29305 \u24500 \u12434 \u12418 \u12387 \u12390 \u12356 \u12427 \u12290 `];\
      \}\
      if (entry.pos === 'adverb') \{\
        return [`She answered the question $\{entry.word\}.`, `\uc0\u24444 \u22899 \u12399 \u12381 \u12398 \u36074 \u21839 \u12395 \u12381 \u12398 \u12424 \u12358 \u12395 \u31572 \u12360 \u12383 \u12290 `];\
      \}\
      return [`The lesson gave us a better understanding of $\{entry.word\}.`, `\uc0\u12381 \u12398 \u25480 \u26989 \u12391 \u31169 \u12383 \u12385 \u12399  $\{entry.word\} \u12408 \u12398 \u29702 \u35299 \u12434 \u28145 \u12417 \u12383 \u12290 `];\
    \}\
\
    function makeExample(entry) \{\
      return EXAMPLE_BANK[entry.word] || genericExample(entry);\
    \}\
\
    function toggleRange(range) \{\
      const exists = state.selectedRanges.some(r => r.start === range.start && r.end === range.end);\
      if (exists) \{\
        state.selectedRanges = state.selectedRanges.filter(r => !(r.start === range.start && r.end === range.end));\
      \} else \{\
        state.selectedRanges = [...state.selectedRanges, range].sort((a, b) => a.start - b.start);\
      \}\
      render();\
    \}\
\
    function speak(text) \{\
      if (!('speechSynthesis' in window)) return;\
      window.speechSynthesis.cancel();\
      const u = new SpeechSynthesisUtterance(text);\
      u.lang = /^[A-Za-z0-9 .,'"!?;:()\\-]+$/.test(text) ? 'en-US' : 'ja-JP';\
      u.rate = 0.95;\
      window.speechSynthesis.speak(u);\
    \}\
\
    function buildQuestions() \{\
      const activeRanges = state.selectedRanges.length ? state.selectedRanges : [RANGE_OPTIONS[0]];\
      const pool = vocab.filter(v => activeRanges.some(r => v.no >= r.start && v.no <= r.end));\
      const picked = sample(pool, Math.min(state.questionCount, pool.length));\
      return picked.map((entry, idx) => \{\
        const samePos = pool.filter(v => v.word !== entry.word && v.meaning !== entry.meaning && v.pos === entry.pos);\
        const fallback = pool.filter(v => v.word !== entry.word && v.meaning !== entry.meaning);\
        const distractorPool = samePos.length >= 4 ? samePos : fallback;\
        const distractors = sample(distractorPool.map(v => v.meaning), 8);\
        const useNone = Math.random() < 0.25;\
        const fakeCorrect = useNone ? sample(distractors, 1)[0] : entry.meaning;\
        const optionsCore = shuffle([fakeCorrect, ...sample(distractors.filter(x => x !== fakeCorrect), 3)]).map(label => (\{\
          label,\
          isCorrect: !useNone && label === entry.meaning,\
        \}));\
        const options = [...optionsCore, \{ label: '\uc0\u12371 \u12398 \u20013 \u12395 \u27491 \u35299 \u12399 \u12394 \u12356 ', isCorrect: useNone, isNone: true \}];\
        const [example, translation] = makeExample(entry);\
        return \{ ...entry, id: `$\{entry.word\}-$\{idx\}`, useNone, options, example, translation \};\
      \});\
    \}\
\
    function resetQuiz() \{\
      clearInterval(state.timerId);\
      state.questions = buildQuestions();\
      state.currentIndex = 0;\
      state.timeLeft = 10;\
      state.selectedLabel = null;\
      state.reveal = false;\
      state.score = 0;\
      state.results = [];\
      state.screen = 'quiz';\
      render();\
      startTimer();\
      autoSpeakCurrentWord();\
    \}\
\
    function startTimer() \{\
      clearInterval(state.timerId);\
      state.timeLeft = 10;\
      state.timerId = setInterval(() => \{\
        state.timeLeft -= 1;\
        if (state.timeLeft <= 0) \{\
          state.timeLeft = 0;\
          clearInterval(state.timerId);\
          revealAnswer(null, true);\
        \}\
        render();\
      \}, 1000);\
    \}\
\
    function currentQuestion() \{\
      return state.questions[state.currentIndex];\
    \}\
\
    function autoSpeakCurrentWord() \{\
      const q = currentQuestion();\
      if (!q) return;\
      setTimeout(() => speak(q.word), 250);\
    \}\
\
    function revealAnswer(label, timedOut = false) \{\
      if (state.reveal) return;\
      clearInterval(state.timerId);\
      const q = currentQuestion();\
      state.selectedLabel = label;\
      state.reveal = true;\
      const selected = q.options.find(o => o.label === label);\
      const correct = timedOut ? false : !!selected?.isCorrect;\
      if (correct) state.score += 1;\
      state.results.push(\{\
        word: q.word,\
        meaning: q.meaning,\
        example: q.example,\
        translation: q.translation,\
        correct,\
        selected: timedOut ? '\uc0\u26178 \u38291 \u20999 \u12428 ' : label,\
        correctText: q.useNone ? '\uc0\u12371 \u12398 \u20013 \u12395 \u27491 \u35299 \u12399 \u12394 \u12356 ' : q.meaning,\
      \});\
      render();\
    \}\
\
    function nextQuestion() \{\
      if (state.currentIndex >= state.questions.length - 1) \{\
        state.screen = 'summary';\
        clearInterval(state.timerId);\
        render();\
        return;\
      \}\
      state.currentIndex += 1;\
      state.timeLeft = 10;\
      state.selectedLabel = null;\
      state.reveal = false;\
      render();\
      startTimer();\
      autoSpeakCurrentWord();\
    \}\
\
    function goHome() \{\
