  <title>Vocab Test App</title>\
  <style>\
    :root \{\
      --bg: #f5f5f7;\
      --card: #ffffff;\
      --text: #111827;\
      --muted: #6b7280;\
      --line: #e5e7eb;\
      --primary: #111827;\
      --primaryText: #ffffff;\
      --okBg: #ecfdf5;\
      --okLine: #10b981;\
      --ngBg: #fef2f2;\
      --ngLine: #ef4444;\
      --soft: #f9fafb;\
    \}\
    * \{ box-sizing: border-box; \}\
    body \{\
      margin: 0;\
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;\
      background: var(--bg);\
      color: var(--text);\
    \}\
    .app \{\
      width: 100%;\
      max-width: 430px;\
      margin: 0 auto;\
      min-height: 100vh;\
      padding: 12px;\
    \}\
    .card \{\
      background: var(--card);\
      border-radius: 24px;\
      box-shadow: 0 10px 30px rgba(0,0,0,.08);\
      overflow: hidden;\
      border: 1px solid rgba(0,0,0,.04);\
    \}\
    .section \{ padding: 16px; \}\
    h1, h2, h3, p \{ margin: 0; \}\
    h1 \{ font-size: 28px; font-weight: 800; \}\
    h2 \{ font-size: 20px; font-weight: 800; \}\
    h3 \{ font-size: 14px; font-weight: 700; color: var(--muted); margin-bottom: 8px; \}\
    .sub \{ color: var(--muted); line-height: 1.6; margin-top: 8px; font-size: 14px; \}\
    .grid-2 \{ display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; \}\
    .grid-3 \{ display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; \}\
    .range-btn, .count-btn, .opt-btn, .ghost-btn, .primary-btn, .icon-btn \{\
      appearance: none; border: 1px solid var(--line); background: #fff; color: var(--text);\
      border-radius: 18px; cursor: pointer;\
    \}\
    .range-btn, .count-btn \{ padding: 12px; text-align: left; \}\
    .range-btn.active, .count-btn.active \{ background: var(--primary); color: var(--primaryText); border-color: var(--primary); \}\
    .range-btn .small \{ font-size: 12px; color: inherit; opacity: .75; margin-top: 4px; display: block; \}\
    .count-btn \{ text-align: center; font-weight: 700; \}\
    .summary-box \{ background: var(--soft); border: 1px solid var(--line); border-radius: 18px; padding: 12px; font-size: 14px; line-height: 1.7; \}\
    .primary-btn \{ width: 100%; background: var(--primary); color: var(--primaryText); border-color: var(--primary); padding: 14px; font-size: 16px; font-weight: 800; \}\
    .primary-btn:disabled \{ opacity: .45; cursor: not-allowed; \}\
    .ghost-btn \{ width: 100%; padding: 12px; font-size: 15px; font-weight: 700; background: #fff; \}\
    .row \{ display: flex; align-items: center; justify-content: space-between; gap: 8px; \}\
    .progress-wrap \{ padding: 14px 16px 10px; border-bottom: 1px solid var(--line); position: sticky; top: 0; background: #fff; z-index: 2; \}\
    .progress-bar \{ width: 100%; height: 8px; background: #eceef2; border-radius: 999px; overflow: hidden; margin-top: 8px; \}\
    .progress-fill \{ height: 100%; width: 100%; background: #111827; transition: width 1s linear; \}\
    .word-box \{ background: var(--soft); border: 1px solid var(--line); border-radius: 24px; padding: 16px; \}\
    .word \{ font-size: 34px; font-weight: 800; letter-spacing: .2px; word-break: break-word; \}\
    .tiny \{ color: var(--muted); font-size: 12px; margin-bottom: 6px; \}\
    .icon-btn \{ width: 44px; height: 44px; display: inline-flex; align-items: center; justify-content: center; font-size: 18px; \}\
    .opts \{ display: grid; gap: 8px; \}\
    .opt-btn \{ width: 100%; text-align: left; padding: 14px; font-size: 14px; line-height: 1.6; \}\
    .opt-btn.none \{ background: var(--soft); \}\
    .opt-btn.correct \{ background: var(--okBg); border-color: var(--okLine); \}\
    .opt-btn.wrong \{ background: var(--ngBg); border-color: var(--ngLine); \}\
    .result-card \{ margin-top: 8px; background: #fff; border: 1px solid var(--line); border-radius: 24px; padding: 14px; \}\
    .badge \{ display: inline-flex; align-items: center; gap: 6px; font-weight: 800; font-size: 15px; margin-bottom: 10px; \}\
    .ok \{ color: #047857; \}\
    .ng \{ color: #b91c1c; \}\
    .result-body \{ display: grid; gap: 8px; font-size: 14px; line-height: 1.7; \}\
    .example-row \{ display: flex; align-items: flex-start; gap: 8px; \}\
    .example-text \{ flex: 1; \}\
    .score-big \{ font-size: 52px; font-weight: 800; text-align: center; \}\
    .split \{ display: grid; grid-template-columns: repeat(2,1fr); gap: 8px; \}\
    .tile \{ border-radius: 18px; padding: 12px; text-align: center; font-size: 14px; \}\
    .tile.ok \{ background: var(--okBg); color: #065f46; \}\
    .tile.ng \{ background: var(--ngBg); color: #991b1b; \}\
    .history-card \{ background: #fff; border-radius: 22px; border: 1px solid var(--line); padding: 14px; margin-top: 10px; \}\
    .history-head \{ display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 8px; \}\
    .status-pill \{ font-size: 12px; padding: 4px 8px; border-radius: 999px; font-weight: 700; \}\
    .status-pill.ok \{ background: var(--okBg); color: #065f46; \}\
    .status-pill.ng \{ background: var(--ngBg); color: #991b1b; \}\
    .mt-12 \{ margin-top: 12px; \}\
    .hidden \{ display: none !important; \}\
  </style>\
