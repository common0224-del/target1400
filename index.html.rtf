    const RANGE_OPTIONS = Array.from(\{length: 14\}, (_, i) => (\{\
      label: `$\{i*100+1\}\'96$\{i*100+100\}`,\
      start: i*100+1,\
      end: i*100+100,\
    \}));\
\
    const state = \{\
      screen: 'home',\
      selectedRanges: [RANGE_OPTIONS[0]],\
      questionCount: 10,\
      questions: [],\
      currentIndex: 0,\
      timeLeft: 10,\
      selectedLabel: null,\
      reveal: false,\
      score: 0,\
