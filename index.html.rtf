            <div class="split">\
              <div class="tile ok">\uc0\u27491 \u35299 <br><span style="font-size:24px;font-weight:800;">$\{state.score\}</span></div>\
              <div class="tile ng">\uc0\u19981 \u27491 \u35299 <br><span style="font-size:24px;font-weight:800;">$\{state.questions.length - state.score\}</span></div>\
            </div>\
            <div class="split">\
              <button class="ghost-btn" onclick="goHome()">\uc0\u12507 \u12540 \u12512 </button>\
              <button class="primary-btn" onclick="resetQuiz()">\uc0\u20877 \u25361 \u25126 </button>\
            </div>\
          </div>\
        </div>\
        $\{state.results.map((r, i) => `\
          <div class="history-card">\
            <div class="history-head">\
              <div style="font-size:20px;font-weight:800;">$\{i + 1\}. $\{r.word\}</div>\
              <span class="status-pill $\{r.correct ? 'ok' : 'ng'\}">$\{r.correct ? '\uc0\u27491 \u35299 ' : '\u19981 \u27491 \u35299 '\}</span>\
            </div>\
            <div style="display:grid; gap:8px; font-size:14px; line-height:1.7;">\
              <div><strong>\uc0\u24847 \u21619 \u65306 </strong>$\{r.meaning\}</div>\
              <div class="example-row">\
                <div class="example-text"><strong>\uc0\u20363 \u25991 \u65306 </strong>$\{r.example\}</div>\
                <button class="icon-btn" onclick="speak($\{JSON.stringify(r.example)\})">\uc0\u55357 \u56586 </button>\
              </div>\
              <div><strong>\uc0\u35379 \u65306 </strong>$\{r.translation\}</div>\
            </div>\
          </div>`).join('')\}\
      `;\
    \}\
\
    function render() \{\
      const app = document.getElementById('app');\
      if (state.screen === 'home') app.innerHTML = homeHTML();\
      else if (state.screen === 'quiz') app.innerHTML = quizHTML();\
      else app.innerHTML = summaryHTML();\
    \}\
\
    function setQuestionCount(n) \{ state.questionCount = n; render(); \}\
\
    window.toggleRange = toggleRange;\
    window.setQuestionCount = setQuestionCount;\
    window.resetQuiz = resetQuiz;\
    window.revealAnswer = revealAnswer;\
    window.nextQuestion = nextQuestion;\
    window.goHome = goHome;\
    window.speak = speak;\
\
    render();\
  </script>\
</body>\
</html>\
}